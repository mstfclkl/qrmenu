@{ ViewData["Title"] = "Create Owner Account"; }
<div class="page-sm">
    <div class="page-header"><h1>Create owner account</h1><p>Create a restaurant owner account directly without self-registration.</p></div>
    <div class="card">
        <form asp-action="CreateOwner" method="post">@Html.AntiForgeryToken()
            <div class="form-row">
                <div class="form-group"><label>First name *</label><input type="text" name="firstName" placeholder="Maria" required /></div>
                <div class="form-group"><label>Last name</label><input type="text" name="lastName" placeholder="Rossi" /></div>
            </div>
            <div class="form-group"><label>Email address *</label><input type="email" name="email" placeholder="owner@restaurant.com" required /></div>
            <div class="form-group"><label>Temporary password *</label><input type="password" name="password" placeholder="Min. 8 chars, upper, lower, digit, symbol" required /><span class="form-hint">Owner should change this on first login.</span></div>
            <div class="btn-row" style="margin-top:8px"><button type="submit" class="btn btn-primary">Create account</button><a asp-action="Owners" class="btn btn-secondary">Cancel</a></div>
        </form>
    </div>
</div>