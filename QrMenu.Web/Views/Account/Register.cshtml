@{ ViewData["Title"] = "Create account"; Layout = "_Layout"; }
<div class="auth-page">
    <div class="auth-card">
        <h2>Open your restaurant</h2>
        <p>Create a free account to start building your digital menu.</p>
        <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:16px;font-size:0.9rem;background:#fde8e6;padding:12px;border-radius:7px"></div>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div class="form-row">
                <div class="form-group"><label>First name</label><input type="text" name="firstName" placeholder="Maria" required /></div>
                <div class="form-group"><label>Last name</label><input type="text" name="lastName" placeholder="Rossi" required /></div>
            </div>
            <div class="form-group"><label>Email address</label><input type="email" name="email" placeholder="you@example.com" required autocomplete="email" /></div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Min. 8 characters" required autocomplete="new-password" />
                <span class="form-hint">Min. 8 chars with uppercase, lowercase, digit and symbol.</span>
            </div>
            <div class="form-group"><label>Confirm password</label><input type="password" name="confirmPassword" placeholder="Repeat your password" required autocomplete="new-password" /></div>
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px;margin-top:4px">Create account</button>
        </form>
        <hr class="divider" style="margin:24px 0" />
        <p style="text-align:center;font-size:0.875rem;color:var(--ink-2)">Already have an account? <a asp-action="Login">Sign in →</a></p>
    </div>
</div>
