@{ ViewData["Title"] = "Forgot password"; Layout = "_Layout"; }
<div class="auth-page"><div class="auth-card">
    <div style="text-align:center;margin-bottom:28px"><div style="font-size:2.5rem;margin-bottom:12px">🔑</div><h2 style="margin-bottom:6px">Forgot your password?</h2><p style="color:var(--ink-2);margin:0">Enter your email and we will send a reset link.</p></div>
    <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:16px;font-size:0.9rem;background:#fde8e6;padding:12px;border-radius:7px"></div>
    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <div class="form-group"><label for="email">Email address</label><input type="email" name="email" id="email" placeholder="you@example.com" required autocomplete="email" autofocus /></div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px">Send reset link</button>
    </form>
    <hr class="divider" style="margin:24px 0" />
    <p style="text-align:center;font-size:0.875rem;color:var(--ink-2)">Remember your password? <a asp-action="Login">Sign in →</a></p>
</div></div>
