@{ ViewData["Title"] = "Reset password"; Layout = "_Layout"; }
<div class="auth-page"><div class="auth-card">
    <div style="text-align:center;margin-bottom:28px"><div style="font-size:2.5rem;margin-bottom:12px">🔒</div><h2 style="margin-bottom:6px">Set new password</h2><p style="color:var(--ink-2);margin:0">Choose a strong password for your account.</p></div>
    <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:16px;font-size:0.9rem;background:#fde8e6;padding:12px;border-radius:7px"></div>
    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="userId" value="@ViewBag.UserId" /><input type="hidden" name="token" value="@ViewBag.Token" />
        <div class="form-group"><label>New password</label><input type="password" name="newPassword" placeholder="Min. 8 characters" required autocomplete="new-password" autofocus /><span class="form-hint">Min. 8 chars with uppercase, lowercase, digit and symbol.</span></div>
        <div class="form-group"><label>Confirm new password</label><input type="password" name="confirmPassword" placeholder="Repeat password" required autocomplete="new-password" /></div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:11px">Reset password</button>
    </form>
</div></div>
