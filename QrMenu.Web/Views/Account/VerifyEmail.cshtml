@{ ViewData["Title"] = "Verify your email"; Layout = "_Layout"; var email = ViewBag.Email as string ?? ""; var smtpOk = ViewBag.SmtpConfigured as bool? ?? false; var devCode = ViewBag.DevCode as string; }
<div class="auth-page">
  <div class="auth-card" style="max-width:460px">
    <div style="text-align:center;margin-bottom:28px">
      <div style="font-size:3rem;margin-bottom:12px">📧</div>
      <h2 style="margin-bottom:6px">Verify your email</h2>
      @if (smtpOk) { <p style="margin:0;color:var(--ink-2)">We sent a 6-digit code to<br/><strong style="color:var(--accent)">@email</strong></p> }
      else { <p style="margin:0;color:var(--ink-2)">Enter the code below to activate your account.</p> }
    </div>
    @if (!smtpOk) {
      <div style="background:#fef3cd;border:1px solid #f0c040;border-radius:10px;padding:16px 20px;margin-bottom:20px">
        <div style="font-size:0.78rem;font-weight:600;color:#7a5010;margin-bottom:6px">⚙️ SMTP not configured — dev mode</div>
        <div style="font-size:0.85rem;color:#5a3a08;margin-bottom:8px">Set Smtp:Username and Smtp:Password in appsettings.json to send real emails.</div>
        @if (devCode != null) {
          <div style="background:white;border:1px solid #f0c040;border-radius:7px;padding:12px;text-align:center;margin-top:8px">
            <div style="font-size:0.75rem;color:#7a5010;margin-bottom:4px">Your verification code:</div>
            <div style="font-size:2.2rem;font-weight:700;letter-spacing:10px;color:#c8420a;font-family:monospace">@devCode</div>
          </div>
        }
      </div>
    }
    @if (TempData["Success"] != null) { <div style="background:#d1f0de;color:#1a5e35;padding:12px;border-radius:8px;font-size:0.875rem;margin-bottom:16px;text-align:center">✓ @TempData["Success"]</div> }
    @if (TempData["Error"] != null) { <div style="background:#fde8e6;color:#7a1f1a;padding:12px;border-radius:8px;font-size:0.875rem;margin-bottom:16px;text-align:center">⚠ @TempData["Error"]</div> }
    <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:16px;font-size:0.9rem;background:#fde8e6;padding:12px;border-radius:7px;text-align:center"></div>
    <form asp-action="VerifyEmail" method="post">
      @Html.AntiForgeryToken()
      <div class="form-group" style="margin-bottom:24px">
        <label for="code" style="text-align:center;display:block;margin-bottom:10px;font-weight:500">Enter your 6-digit code</label>
        <input type="text" name="code" id="code" maxlength="6" placeholder="000000" autocomplete="one-time-code" inputmode="numeric" autofocus
          style="text-align:center;font-size:2rem;font-weight:700;letter-spacing:10px;font-family:monospace;padding:16px;border:2px solid var(--border);border-radius:10px;width:100%;transition:border-color 0.15s" />
        <p style="text-align:center;font-size:0.8rem;color:var(--ink-3);margin-top:8px">Code expires in 15 minutes</p>
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;padding:12px;font-size:1rem">Verify email →</button>
    </form>
    <hr class="divider" style="margin:24px 0" />
    <div style="text-align:center">
      <p style="font-size:0.875rem;color:var(--ink-2);margin-bottom:12px">Didn't receive the code?</p>
      <form asp-action="ResendCode" method="post" style="display:inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-secondary btn-sm" id="resendBtn">Resend code</button>
      </form>
    </div>
    <p style="text-align:center;font-size:0.8rem;color:var(--ink-3);margin-top:20px">Wrong email? <a asp-action="Register">Start over</a></p>
  </div>
</div>
@section Scripts {
<script>
const inp=document.getElementById('code');
inp.addEventListener('input',function(){this.value=this.value.replace(/[^0-9]/g,'').slice(0,6);if(this.value.length===6){this.style.borderColor='var(--success,#2d7a4f)';setTimeout(()=>this.closest('form').submit(),300);}else{this.style.borderColor='var(--border)';}});
document.getElementById('resendBtn')?.addEventListener('click',function(){this.disabled=true;this.textContent='Sending...';this.closest('form').submit();});
</script>
}
