@using QrMenu.Infrastructure.Services
@{
    ViewData["Title"] = "Restaurant Stats";
    var restaurant = ViewBag.Restaurant as QrMenu.Application.DTOs.RestaurantDto;
    var stats = ViewBag.Stats as ScanStats;
    var soldOut = ViewBag.SoldOutItems as List<QrMenu.Application.DTOs.MenuItemDto> ?? new();
    var totalItems = (int)(ViewBag.TotalItems ?? 0);
}
<div class="page">
    <div class="page-header-row page-header">
        <div><h1>@restaurant!.Name — Stats</h1><p>QR scan analytics and menu overview</p></div>
        <div class="btn-row">
            <a asp-action="ManageRestaurant" asp-route-id="@restaurant.Id" class="btn btn-secondary">← Back to menu</a>
        </div>
    </div>
    <div class="stat-grid" style="grid-template-columns:repeat(auto-fill,minmax(150px,1fr))">
        <div class="stat-card"><div class="stat-label">Total scans</div><div class="stat-value accent">@stats!.TotalScans</div></div>
        <div class="stat-card"><div class="stat-label">Today</div><div class="stat-value">@stats.ScansToday</div></div>
        <div class="stat-card"><div class="stat-label">This week</div><div class="stat-value">@stats.ScansThisWeek</div></div>
        <div class="stat-card"><div class="stat-label">This month</div><div class="stat-value">@stats.ScansThisMonth</div></div>
        <div class="stat-card"><div class="stat-label">Menu items</div><div class="stat-value">@totalItems</div></div>
        <div class="stat-card"><div class="stat-label">Sold out now</div><div class="stat-value" style="color:var(--danger)">@soldOut.Count</div></div>
    </div>

    <div class="card" style="margin-bottom:32px">
        <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:600;margin-bottom:20px">Scans — last 7 days</h2>
        @if (stats.Last7Days.All(d => d.Count == 0)) {
            <div style="text-align:center;padding:40px;color:var(--ink-3)"><div style="font-size:2rem;margin-bottom:8px">📊</div><p>No scan data yet. Share your QR code to start tracking!</p></div>
        } else {
            var maxCount = Math.Max(1, stats.Last7Days.Max(d => d.Count));
            <div style="display:flex;align-items:flex-end;gap:12px;height:140px;padding-bottom:8px">
                @foreach (var day in stats.Last7Days) {
                    var h = (int)(day.Count * 100.0 / maxCount);
                    var isToday = day.Date.Date == DateTime.Today;
                    <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px">
                        <span style="font-size:0.78rem;font-weight:600;color:var(--ink-2)">@day.Count</span>
                        <div style="width:100%;background:@(isToday?"var(--accent)":"var(--paper-3)");border-radius:4px 4px 0 0;height:@(Math.Max(h,2))%;min-height:4px"></div>
                        <span style="font-size:0.72rem;color:var(--ink-3)">@day.Date.ToString("ddd")</span>
                    </div>
                }
            </div>
        }
    </div>

    @if (soldOut.Any()) {
        <div class="card" style="margin-bottom:32px">
            <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:600;margin-bottom:16px">🔴 Currently sold out (@soldOut.Count items)</h2>
            <div style="display:flex;flex-direction:column;gap:8px">
                @foreach (var item in soldOut) {
                    <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;background:var(--paper-2);border-radius:8px">
                        <span style="font-weight:500;font-size:0.9rem">@item.Name</span>
                        <div class="btn-row">
                            <span style="font-family:var(--font-display);font-size:1rem;color:var(--accent)">@restaurant.CurrencySymbol@item.Price.ToString("F2")</span>
                            <form asp-controller="Owner" asp-action="ToggleSoldOut" asp-route-id="@item.Id" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="restaurantId" value="@restaurant.Id" />
                                <button class="btn btn-success btn-sm">Mark available</button>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    <div class="card" style="border-color:rgba(176,58,46,0.2);margin-top:40px">
        <h2 style="font-family:var(--font-display);font-size:1.2rem;font-weight:600;color:var(--danger);margin-bottom:8px">Danger zone</h2>
        <p style="color:var(--ink-2);font-size:0.875rem;margin-bottom:16px">Permanently delete your account and all restaurant data.</p>
        <button class="btn btn-danger btn-sm" onclick="document.getElementById('deleteModal').style.display='flex'">Delete my account</button>
    </div>
</div>

<div id="deleteModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:9999;align-items:center;justify-content:center;padding:24px">
    <div style="background:white;border-radius:14px;padding:32px;max-width:440px;width:100%">
        <h3 style="font-family:var(--font-display);font-size:1.4rem;margin-bottom:8px;color:var(--danger)">Delete account</h3>
        <p style="color:var(--ink-2);font-size:0.875rem;margin-bottom:20px">Type <strong>DELETE</strong> to permanently remove your account and all data.</p>
        <form asp-controller="Account" asp-action="DeleteAccount" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group"><input type="text" name="confirmText" placeholder="Type DELETE here" autocomplete="off" style="text-transform:uppercase;font-weight:600;border-color:var(--danger)" /></div>
            <div class="btn-row">
                <button type="submit" class="btn btn-danger">Permanently delete</button>
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('deleteModal').style.display='none'">Cancel</button>
            </div>
        </form>
    </div>
</div>
