@model QrMenu.Application.DTOs.CreateMenuItemDto
@{ ViewData["Title"] = "Edit Menu Item"; var restaurantId = ViewBag.RestaurantId as int? ?? 0; var itemId = ViewContext.RouteData.Values["id"]; var categories = ViewBag.Categories as List<QrMenu.Application.DTOs.CategoryDto> ?? new(); }
<div class="page-sm">
    <div class="page-header"><h1>Edit menu item</h1></div>
    <div class="card">
        <form asp-action="EditItem" asp-route-id="@itemId" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="restaurantId" value="@restaurantId" />
            <div asp-validation-summary="ModelOnly" style="color:var(--danger);margin-bottom:16px;font-size:0.9rem;background:#fde8e6;padding:12px;border-radius:7px"></div>
            <div class="form-group">
                <label asp-for="CategoryId">Category *</label>
                <select asp-for="CategoryId" required>
                    <option value="">— Select a category —</option>
                    @foreach (var cat in categories) { <option value="@cat.Id" selected="@(Model.CategoryId==cat.Id)">@cat.Name</option> }
                </select>
            </div>
            <div class="form-row">
                <div class="form-group"><label asp-for="Name">Name (Turkish) *</label><input asp-for="Name" /><span asp-validation-for="Name" style="color:var(--danger);font-size:0.82rem"></span></div>
                <div class="form-group"><label asp-for="NameEn">Name (English)</label><input asp-for="NameEn" /></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label asp-for="Description">Description (TR)</label><textarea asp-for="Description" rows="2"></textarea></div>
                <div class="form-group"><label asp-for="DescriptionEn">Description (EN)</label><textarea asp-for="DescriptionEn" rows="2"></textarea></div>
            </div>
            <div class="form-row">
                <div class="form-group"><label asp-for="Price">Price *</label><input asp-for="Price" type="number" step="0.01" min="0" max="99999" /><span asp-validation-for="Price" style="color:var(--danger);font-size:0.82rem"></span></div>
                <div class="form-group"><label asp-for="DisplayOrder">Display order</label><input asp-for="DisplayOrder" type="number" min="0" /></div>
            </div>
            <div class="form-group"><label asp-for="Tags">Tags</label><input asp-for="Tags" placeholder="vegan, gluten-free, spicy" /><span class="form-hint">Comma-separated labels.</span></div>
            <div class="form-group"><label asp-for="Allergens">Allergens</label><input asp-for="Allergens" placeholder="gluten, dairy, nuts" /></div>
            <div style="display:flex;gap:20px;flex-wrap:wrap;margin-bottom:20px">
                <label class="input-checkbox"><input asp-for="IsAvailable" type="checkbox" /><span>Available now</span></label>
                <label class="input-checkbox"><input asp-for="IsSoldOut" type="checkbox" /><span>🔴 Sold out</span></label>
                <label class="input-checkbox"><input asp-for="IsFeatured" type="checkbox" /><span>⭐ Chef's pick</span></label>
                <label class="input-checkbox"><input asp-for="IsDailySpecial" type="checkbox" /><span>🌟 Daily special</span></label>
            </div>
            <!-- Photo upload — separate form so it doesn't interfere with item save -->
            <div style="background:var(--paper-2);border-radius:var(--radius);padding:16px;margin-bottom:20px">
                <label style="font-size:0.875rem;font-weight:500;color:var(--ink-2);display:block;margin-bottom:8px">Upload photo</label>
                <form asp-action="UploadItemImage" asp-route-id="@itemId" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="restaurantId" value="@restaurantId" />
                    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
                        <input type="file" name="file" accept="image/*" style="font-size:0.85rem;flex:1" />
                        <button type="submit" class="btn btn-secondary btn-sm">Upload</button>
                    </div>
                </form>
            </div>
            <div class="btn-row">
                <button type="submit" class="btn btn-primary">Save changes</button>
                <a asp-action="ManageRestaurant" asp-route-id="@restaurantId" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
